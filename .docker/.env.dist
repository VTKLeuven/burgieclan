APP_SECRET=replaceThisEnvVariable
POSTGRES_PASSWORD=replaceThisEnvVariable
LITUS_API_KEY=replaceThisEnvVariable
LITUS_SECRET=notUsedInLitus
SENTRY_DSN=
JWT_PASSPHRASE=replaceThisEnvVariable
DATA_DIR=./data
JWT_DIR=./jwt
POSTGRES_DATA_DIR=./postgres_data

# Hetzner Object Storage (S3-compatible). Required for production file uploads.
S3_BUCKET=burgieclan-vtk
S3_ENDPOINT=https://nbg1.your-objectstorage.com
S3_REGION=nbg1
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_USE_PATH_STYLE_ENDPOINT=true
# One-time: copy this file to .docker/.env, fill keys, install `aws` CLI v2, then:
#   make sync-documents-to-s3-dry-run
#   make sync-documents-to-s3